{
  "name": "webaibuilder",
  "version": "0.0.0",
  "private": true,
  "description": "Web AI Builder — Desktop-Client: Webseiten per KI-Chat bauen und auf klassischen Webspace deployen.",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @webaibuilder/desktop dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "package": "pnpm --filter @webaibuilder/desktop package",
    "package:linux": "pnpm --filter @webaibuilder/desktop package:linux"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
