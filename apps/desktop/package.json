{
  "name": "@webaibuilder/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Web AI Builder — Electron desktop app (main, preload, renderer).",
  "author": "AdminCave <mail@kevin-stenzel.de>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/rebuild-native.mjs electron --if-needed && electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "node scripts/rebuild-native.mjs node --if-needed && vitest run",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "package": "pnpm rebuild:electron && electron-vite build && electron-builder",
    "package:linux": "pnpm rebuild:electron && electron-vite build && electron-builder --linux",
    "package:dir": "pnpm rebuild:electron && electron-vite build && electron-builder --dir",
    "rebuild:electron": "node scripts/rebuild-native.mjs electron",
    "rebuild:node": "node scripts/rebuild-native.mjs node"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@webaibuilder/agents": "workspace:*",
    "@webaibuilder/core": "workspace:*",
    "@webaibuilder/deploy": "workspace:*",
    "@webaibuilder/preview": "workspace:*",
    "@webaibuilder/versioning": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "vite": "^8.1.4"
  }
}
